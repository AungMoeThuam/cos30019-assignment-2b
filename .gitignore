# ==========================================
# Project-Specific Ignores (Assignment 2B)
# ==========================================

# Ignore raw data files (Excel spreadsheets and PDFs are large and kept locally)
# data/raw/*
!data/raw/.gitkeep

# Ignore processed data outputs
# data/processed/*
!data/processed/.gitkeep

# Ignore saved models (trained checkpoints)
# models_saved/*
!models_saved/.gitkeep

# Ignore runtime visualization maps and outputs
osm_map.png
map.txt
